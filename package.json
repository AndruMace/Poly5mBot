{
  "name": "5mtracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "cd server && bun run dev",
    "dev:server:sync": "cd server && bun run build && (bun run build --watch & bun run dev)",
    "dev:all": "bun run dev:server:sync & bun run dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "npm run test:unit:server && npm run test:unit:client",
    "test:unit:server": "npm --prefix server run test:unit",
    "test:unit:client": "vitest run --config vitest.config.ts",
    "test:integration": "npm --prefix server run test:integration",
    "test:live": "npm --prefix server run test:live",
    "test:e2e": "playwright test",
    "test:coverage": "npm --prefix server run test:coverage && vitest run --config vitest.config.ts --coverage"
  },
  "dependencies": {
    "@effect-rx/rx": "^0.48.7",
    "@effect-rx/rx-react": "^0.42.4",
    "@tailwindcss/vite": "^4.2.0",
    "effect": "^3.19.19",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.4",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@effect/language-service": "^0.77.0",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.3"
  }
}
