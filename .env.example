# Polymarket credentials
POLY_PRIVATE_KEY=your_wallet_private_key_here
POLY_SIGNATURE_TYPE=2
# 0 = EOA, 1 = POLY_PROXY, 2 = GNOSIS_SAFE (most common)
POLY_PROXY_ADDRESS=
# Your Polymarket proxy wallet address (required for GNOSIS_SAFE)

# Derived API credentials (auto-generated on first run if empty)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Risk management
MAX_TRADE_SIZE=10
MAX_TOTAL_EXPOSURE=100
MAX_DAILY_LOSS=50
MAX_CONCURRENT_POSITIONS=5
MAX_HOURLY_LOSS=25
MAX_LOSS_PER_WINDOW=2
MAX_CONSECUTIVE_LOSSES=5
STALE_DATA_MS=5000
MAX_SPREAD_CENTS=15
MAX_SIGNAL_AGE_MS=2000

MAX_WINDOW_SPEND=10
MAX_WINDOW_TRADES=4

# Trading mode
TRADING_MODE=shadow

# Whale-hunt runtime safety settings
WHALE_HUNT_ORDERBOOK_BAND_PCT=0.05
WHALE_HUNT_MAX_ADVERSE_IMBALANCE=0.12
WHALE_HUNT_IMBALANCE_WEIGHT=0.20
WHALE_HUNT_LATENCY_MULTIPLIER=2.5
WHALE_HUNT_LATENCY_BUFFER_MS=1200
WHALE_HUNT_MIN_REQUIRED_LEAD_MS=4000
WHALE_HUNT_MIN_LIVE_SUBMITTED_FOR_SIZING=40

# Server
SERVER_PORT=3001
OPERATOR_TOKEN=

# Storage backend
# file = existing JSON/JSONL files
# dual = write both file + postgres (migration mode)
# postgres = postgres-only runtime
STORAGE_BACKEND=postgres
DATABASE_URL=

# Test / CI
CI_LIVE_INTEGRATION=false
LIVE_TEST_TIMEOUT_MS=15000
PLAYWRIGHT_BASE_URL=http://127.0.0.1:5173
TEST_OPERATOR_TOKEN=test-operator-token
